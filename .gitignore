# Git 忽略文件 - 保护隐私和敏感数据

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db

# 备份文件
backups/*.tar.gz

# 敏感配置文件
*.env
*.secret
config.local.*

# node_modules (所有项目的依赖)
**/node_modules/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.eggs/
*.egg-info/
dist/
build/

# 虚拟环境
venv/
env/
.venv/
pptx_venv/

# IDE
.idea/
.vscode/

# OpenClaw 状态文件
.openclaw/
